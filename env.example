# mph-agent 环境变量示例
# 复制此文件为 .env 并填写实际值。不要将 .env 提交到仓库。

# ----- LLM 后端（仅支持: deepseek | kimi | ollama | openai-compatible）-----
# 不设置时默认 ollama
LLM_BACKEND=ollama

# ----- DeepSeek -----
# 当 LLM_BACKEND=deepseek 时必填
DEEPSEEK_API_KEY=
# 默认 reasoner；可选 deepseek-chat
DEEPSEEK_MODEL=deepseek-reasoner

# ----- Kimi (Moonshot) -----
# 当 LLM_BACKEND=kimi 时必填
KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-8k

# ----- 符合 OpenAI 规范的中转 API -----
# 当 LLM_BACKEND=openai-compatible 时必填
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=gpt-3.5-turbo

# ----- Ollama（本地/远程）-----
# 当 LLM_BACKEND=ollama 时使用；不需要 API Key
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ----- COMSOL -----
# COMSOL 6.3 plugins 目录，必填（本项目面向 COMSOL Multiphysics 6.3 开发）
COMSOL_JAR_PATH=
# 可选：本地 COMSOL 文档目录、Multiphysics 根目录或 plugins 目录。
# 用于 scripts/import_comsol_docs.py 构建本地文档知识库；未设置时会回退到 COMSOL_JAR_PATH。
# COMSOL_DOC_PATH=
# COMSOL 本地库目录（含 JNI .dll/.so），解决 UnsatisfiedLinkError: FlLicense.initWS0；不填则按 COMSOL_JAR_PATH 自动推导 bin/win64 等
# COMSOL_NATIVE_PATH=
# Java 安装目录，可选：不设置时优先用系统 JAVA_HOME，否则首次使用会自动下载内置 JDK 11 到项目 runtime/java
# JAVA_HOME=
# 内置 JDK 11 下载镜像：留空用官方；国内加速可设为 tsinghua（清华 TUNA 镜像）
# JAVA_DOWNLOAD_MIRROR=tsinghua
# 环境已就绪、不需自动下载 JDK 时设为 1，仅使用已存在的 JAVA_HOME 或 runtime/java
# JAVA_SKIP_AUTO_DOWNLOAD=1

# ----- 内置 claw-code COMSOL 调度 -----
# 开启后，mph-agent 的 COMSOL 执行动作会交给内置 claw-code 库调度（不再依赖外部 claw-code 路径/子进程）
CLAW_CODE_ENABLED=1
CLAW_CODE_MAX_TURNS=12
CLAW_CODE_TIMEOUT_SECONDS=120
# 可选：覆盖 claw-code agent 的 OpenAI-compatible 后端配置
# CLAW_CODE_MODEL=
# CLAW_CODE_BASE_URL=
# CLAW_CODE_API_KEY=

# ----- 输出与日志 -----
# 模型输出目录，不设置时默认为安装目录下的 models
# MODEL_OUTPUT_DIR=
# 日志级别: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
